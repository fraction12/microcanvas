{
  "name": "microcanvas",
  "version": "1.0.0",
  "description": "A tiny file-first canvas runtime for AI tools.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/fraction12/microcanvas#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fraction12/microcanvas.git"
  },
  "bugs": {
    "url": "https://github.com/fraction12/microcanvas/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "canvas",
    "cli",
    "presentation",
    "viewer"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "skills/microcanvas-present"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "microcanvas": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && npm run build:tsc",
    "build:tsc": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "check": "tsc -p tsconfig.json --noEmit",
    "pack:dry-run": "npm run build && npm pack --dry-run",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.mjs",
    "build:viewer-app": "sh apps/macos-viewer/scripts/build-app-bundle.sh",
    "install:skills": "bash skills/microcanvas-present/scripts/install-agent-skill.sh"
  },
  "dependencies": {
    "agenttk": "^0.1.5",
    "marked": "^15.0.12",
    "picocolors": "^1.1.1",
    "sanitize-html": "^2.13.0",
    "mermaid": "^11.12.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^5.8.3"
  }
}
